<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>H&S | Human & Success</title>

<!-- FONT -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<!-- GSAP -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Pretendard',sans-serif;
}

html{
  scroll-behavior:smooth;
}

body{
  background:#f7f8fb;
  overflow-x:hidden;
  color:#111;
}

/* HEADER */

header{
  width:100%;
  height:92px;

  position:fixed;
  top:0;
  left:0;
  z-index:1000;

  display:flex;
  justify-content:space-between;
  align-items:center;

  padding:0 80px;

  background:rgba(255,255,255,0.82);
  backdrop-filter:blur(18px);

  border-bottom:1px solid rgba(0,0,0,0.04);
}

.logo img{
  height:58px;
}

nav{
  display:flex;
  gap:42px;
}

nav a{
  text-decoration:none;
  color:#111;
  font-weight:600;
  font-size:15px;
  position:relative;
}

nav a::after{
  content:'';
  position:absolute;
  left:0;
  bottom:-7px;

  width:0%;
  height:2px;

  background:#14398f;
  transition:.4s;
}

nav a:hover::after{
  width:100%;
}

.contact-btn{
  padding:14px 28px;
  border-radius:999px;

  background:#14398f;
  color:white;

  text-decoration:none;
  font-weight:600;

  transition:.4s;
}

.contact-btn:hover{
  transform:translateY(-3px);
  box-shadow:0 15px 35px rgba(20,57,143,0.25);
}

/* HERO */

.hero{
  width:100%;
  min-height:100vh;

  display:flex;
  justify-content:space-between;
  align-items:center;

  padding:140px 80px 80px;

  position:relative;
  overflow:hidden;

  background:
  radial-gradient(circle at top right, rgba(20,57,143,0.08), transparent 40%);
}

.hero-left{
  width:46%;
  position:relative;
  z-index:2;
}

.hero-sub{
  color:#14398f;
  font-weight:700;
  margin-bottom:24px;
  letter-spacing:1px;
}

.hero-left h1{
  font-size:84px;
  line-height:1.05;
  font-weight:800;
  margin-bottom:34px;
}

.hero-left h1 span{
  color:#14398f;
}

.hero-left p{
  color:#555;
  font-size:21px;
  line-height:1.8;
  margin-bottom:45px;
}

.hero-buttons{
  display:flex;
  gap:18px;
}

.primary-btn{
  padding:18px 36px;
  border-radius:999px;

  background:#14398f;
  color:white;

  text-decoration:none;
  font-weight:600;

  transition:.4s;
}

.primary-btn:hover{
  transform:translateY(-4px);
  box-shadow:0 18px 40px rgba(20,57,143,0.25);
}

.hero-right{
  width:54%;
  position:relative;

  display:flex;
  justify-content:center;
  align-items:center;
}

.hero-image{
  width:100%;
  max-width:950px;

  filter:drop-shadow(0 50px 90px rgba(0,0,0,0.24));
}

/* SECTION */

.section-label{
  color:#14398f;
  font-weight:700;
  font-size:14px;
  margin-bottom:14px;
}

.section-title{
  font-size:58px;
  font-weight:800;
  margin-bottom:18px;
}

.section-sub{
  color:#666;
  font-size:18px;
  line-height:1.8;
}

/* PRODUCTS */

.products{
  width:100%;
  padding:140px 80px;
}

.product-header{
  text-align:center;
  margin-bottom:70px;
}

.product-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:28px;
}

.product-card{
  background:white;
  border-radius:30px;
  overflow:hidden;

  transition:.45s;

  box-shadow:0 12px 35px rgba(0,0,0,0.05);
}

.product-card:hover{
  transform:translateY(-10px);
  box-shadow:0 35px 70px rgba(0,0,0,0.08);
}

.product-card img{
  width:100%;
  height:280px;
  object-fit:cover;
}

.product-content{
  padding:36px;
}

.product-content h3{
  font-size:34px;
  margin-bottom:15px;
}

.product-content p{
  color:#666;
  line-height:1.8;
}

/* APPLICATION */

.application{
  width:100%;
  padding:140px 80px;

  background:
  linear-gradient(rgba(6,17,45,0.92), rgba(6,17,45,0.92)),
  url('https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=2000&auto=format&fit=crop');

  background-size:cover;
  background-position:center;

  color:white;
}

.application-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:24px;

  margin-top:70px;
}

.application-card{
  min-height:450px;

  border-radius:28px;
  overflow:hidden;

  position:relative;

  transition:.45s;
}

.application-card:hover{
  transform:translateY(-10px);
}

.application-card img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.application-card::before{
  content:'';
  position:absolute;
  inset:0;

  background:linear-gradient(to top, rgba(0,0,0,0.88), transparent);
}

.application-content{
  position:absolute;
  left:0;
  bottom:0;

  z-index:2;

  padding:34px;
}

.application-content h3{
  font-size:30px;
  margin-bottom:16px;
}

.application-content p{
  color:rgba(255,255,255,0.82);
  line-height:1.8;
  font-size:15px;
}

/* ABOUT */

.about{
  width:100%;
  padding:140px 80px;
}

.about-top{
  max-width:1100px;
  margin-bottom:70px;
}

.about-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:30px;
}

.about-card{
  background:white;
  border-radius:30px;

  padding:50px;

  box-shadow:0 12px 35px rgba(0,0,0,0.04);
}

.about-card h3{
  font-size:34px;
  margin-bottom:24px;
}

.about-card p{
  color:#666;
  line-height:1.9;
}

.about-card ul{
  padding-left:20px;
}

.about-card li{
  margin-bottom:16px;
  color:#444;
  line-height:1.8;
}

/* QUOTE */

.quote-section{
  width:100%;
  padding:120px 80px;

  background:
  linear-gradient(rgba(8,22,60,0.94), rgba(8,22,60,0.94)),
  url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=2000&auto=format&fit=crop');

  background-size:cover;
  background-position:center;

  color:white;
  text-align:center;
}

.quote{
  max-width:1200px;
  margin:auto;

  font-size:32px;
  line-height:1.9;
  font-weight:500;
}

/* FOOTER */

footer{
  background:#050d1d;
  color:white;
  padding:80px 80px 40px;
}

.footer-top{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;

  margin-bottom:60px;
}

.footer-logo img{
  height:62px;
  margin-bottom:24px;
}

.footer-logo p{
  color:rgba(255,255,255,0.65);
  line-height:1.8;
}

.footer-menu{
  display:flex;
  gap:100px;
}

.footer-menu h4{
  margin-bottom:20px;
}

.footer-menu a{
  display:block;
  color:rgba(255,255,255,0.65);
  text-decoration:none;
  margin-bottom:12px;
}

.footer-bottom{
  border-top:1px solid rgba(255,255,255,0.1);
  padding-top:30px;

  color:rgba(255,255,255,0.45);
}

/* MOBILE */

@media(max-width:1200px){

  header{
    padding:0 30px;
  }

  nav{
    display:none;
  }

  .hero{
    flex-direction:column;
    text-align:center;
    padding:150px 30px 80px;
  }

  .hero-left,
  .hero-right{
    width:100%;
  }

  .hero-left h1{
    font-size:56px;
  }

  .hero-buttons{
    justify-content:center;
  }

  .products,
  .application,
  .about,
  .quote-section{
    padding:100px 30px;
  }

  .product-grid,
  .application-grid,
  .about-grid{
    grid-template-columns:1fr;
  }

  .footer-top{
    flex-direction:column;
    gap:50px;
  }

  .footer-menu{
    flex-wrap:wrap;
    gap:40px;
  }

}

</style>
</head>

<body>

<!-- HEADER -->

<header>

  <div class="logo">
    <!-- 여기 네 로고 파일 넣기 -->
    <img src="logo.png">
  </div>

  <nav>
    <a href="#">회사소개</a>
    <a href="#">제품소개</a>
