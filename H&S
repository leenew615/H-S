        <a href="#">자료실</a>
        <a href="#">공지사항</a>
      </div>

    </div>

  </div>

  <div class="footer-bottom">
    © 2026 H&S Co., Ltd. All rights reserved.
  </div>

</footer>

<!-- GSAP -->

<script>

gsap.registerPlugin(ScrollTrigger);

gsap.from(".hero-left",{
  opacity:0,
  y:80,
  duration:1.2
});

gsap.from(".hero-image",{
  opacity:0,
  scale:.8,
  rotate:5,
  duration:1.5
});

gsap.to(".hero-image",{
  y:-18,
  repeat:-1,
  duration:3,
  yoyo:true,
  ease:"power1.inOut"
});

gsap.from(".product-card",{
  scrollTrigger:{
    trigger:".product-grid",
    start:"top 80%"
  },
  opacity:0,
  y:100,
  stagger:.2,
  duration:1
});

gsap.from(".application-card",{
  scrollTrigger:{
    trigger:".application-grid",
    start:"top 80%"
  },
  opacity:0,
  y:100,
  stagger:.15,
  duration:1
});

gsap.from(".about-card",{
  scrollTrigger:{
    trigger:".about-grid",
    start:"top 80%"
  },
  opacity:0,
  y:80,
  stagger:.2,
  duration:1
});

gsap.from(".quote",{
  scrollTrigger:{
    trigger:".quote",
    start:"top 80%"
  },
  opacity:0,
  y:60,
  duration:1.2
});

</script>

</body>
</html>
